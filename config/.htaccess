# Bloquear todo acceso web directo al directorio config/
# Los archivos PHP dentro de config/ solo pueden ser incluidos
# por otros scripts PHP del servidor — nunca desde el navegador.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
