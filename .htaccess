# ═══════════════════════════════════════════════════════════════════════════════
#  .htaccess de PRODUCCIÓN — EGS Equipo de Cómputo Panel Backend
#  Servidor: Apache / cPanel compartido
# ═══════════════════════════════════════════════════════════════════════════════

# ── Versión de PHP (cPanel) ────────────────────────────────────────────────────
# TODO: actualizar a PHP 8.1+ cuando sea posible (PHP 7.1 sin soporte desde 2019)
# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php71 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ── Motor de reescritura ───────────────────────────────────────────────────────
Options +FollowSymLinks
RewriteEngine On

# Routing limpio: /inicio → index.php?ruta=inicio
RewriteRule ^([-a-zA-Z0-9/]+)$ index.php?ruta=$1

# Redirigir HTTP → HTTPS  (solo en producción — se omite en localhost/127.0.0.1)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|.*\.test)$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirigir www → sin www  (solo en producción)
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|.*\.test)$ [NC]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ── Deshabilitar listado de directorios ────────────────────────────────────────
Options -Indexes

# ── Proteger archivos sensibles ────────────────────────────────────────────────
<FilesMatch "(^\.env$|debug_log\.txt|composer\.(json|lock)|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquear acceso directo a config/ desde el navegador
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
</IfModule>

# ── Headers de seguridad HTTP ──────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Evita clickjacking (iframes de otros dominios)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Evita MIME-sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Protección XSS básica (browsers legacy)
    Header always set X-XSS-Protection "1; mode=block"

    # Controla datos del Referer enviados a terceros
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS: fuerza HTTPS por 1 año
    # ⚠️  Activa SOLO si el certificado SSL está instalado y funcionando
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Oculta la versión de PHP
    Header always unset X-Powered-By
    Header unset X-Powered-By
</IfModule>

# ── Caché de recursos estáticos ────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg            "access plus 1 month"
    ExpiresByType image/png             "access plus 1 month"
    ExpiresByType image/gif             "access plus 1 month"
    ExpiresByType image/webp            "access plus 1 month"
    ExpiresByType image/svg+xml         "access plus 1 month"
    ExpiresByType image/x-icon          "access plus 1 year"
    ExpiresByType text/css              "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/javascript        "access plus 1 week"
    ExpiresByType font/woff              "access plus 1 month"
    ExpiresByType font/woff2             "access plus 1 month"
</IfModule>

# ── Compresión gzip ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript text/javascript
    AddOutputFilterByType DEFLATE application/json image/svg+xml
</IfModule>

# ── Ocultar firma de Apache ────────────────────────────────────────────────────
ServerSignature Off
