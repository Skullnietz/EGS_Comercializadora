# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno para EGS Panel
#
# INSTRUCCIONES:
#   1. Copia este archivo como  .env  en la raíz del proyecto.
#   2. Rellena los valores reales de producción.
#   3. Sube .env al servidor por FTP (NUNCA lo subas al repositorio git).
#   4. El archivo .env está en .gitignore — no aparecerá en commits.
# ─────────────────────────────────────────────────────────────────────────────


# ── Entorno ───────────────────────────────────────────────────────────────────
# "production" | "development"
APP_ENV=production

# Nombre del proyecto (usado en títulos y reportes)
APP_NAME="EGS Equipo de Cómputo"


# ── Base de datos del sistema de ventas (mysqli — config/Conexion.php) ────────
DB_SISTEMA_HOST=localhost
DB_SISTEMA_NAME=egsequip_dbsistema
DB_SISTEMA_USER=egsequip_sistema
DB_SISTEMA_PASS=


# ── Base de datos de e-commerce / productos (PDO — modelos/conexion.php) ──────
DB_ECOMMERCE_HOST=localhost
DB_ECOMMERCE_NAME=egsequip_ecomerce
DB_ECOMMERCE_USER=egsequip_bdecome
DB_ECOMMERCE_PASS=


# ── Base de datos principal: órdenes, pedidos, comisiones ─────────────────────
# (PDO — modelos/conexionWordpress.php)
DB_WORDPRESS_HOST=localhost
DB_WORDPRESS_NAME=egsequip_respaldo
DB_WORDPRESS_USER=egsequip_wp54331
DB_WORDPRESS_PASS=


# ── Correo (PHPMailer) ────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@egsequipodecomputo.com
MAIL_PASSWORD=
MAIL_FROM_NAME="EGS Equipo de Cómputo"
MAIL_ENCRYPTION=tls
